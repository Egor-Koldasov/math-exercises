Checks: >
  clang-diagnostic-*,
  clang-analyzer-*,
  bugprone-*,
  performance-*,
  modernize-*,
  -readability-magic-numbers,
  -modernize-use-trailing-return-type,
  -modernize-use-using,
  -modernize-avoid-c-arrays,
  -bugprone-easily-swappable-parameters
WarningsAsErrors: ""
HeaderFilterRegex: ".*"
FormatStyle: file
